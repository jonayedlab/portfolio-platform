# ----- Database -----
# Default: docker-compose Postgres on localhost
DATABASE_URL="postgresql://portfolio:portfolio@localhost:5432/portfolio?schema=public"

# ----- API server -----
API_PORT=4000
API_BASE_URL="http://localhost:4000"
WEB_ORIGIN="http://localhost:3000"

# ----- Auth -----
# Generate with: openssl rand -base64 48
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="7d"
COOKIE_NAME="portfolio_admin"

# Initial admin user, created by `pnpm db:seed`
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="changeme123!"
ADMIN_NAME="Alifur Rahman Jonayed"

# ----- Storage (Cloudinary) -----
# Optional for MVP; if unset, uploads fall back to local disk.
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
STORAGE_DRIVER="local" # "local" | "cloudinary"

# ----- Web app -----
NEXT_PUBLIC_API_URL="http://localhost:4000"
NEXT_PUBLIC_SITE_NAME="Alifur Rahman Jonayed"
