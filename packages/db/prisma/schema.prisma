// Portfolio + digital marketplace + blog + admin CMS
// Database schema (PostgreSQL via Prisma)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  CUSTOMER
}

enum OrderStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum PostStatus {
  DRAFT
  PUBLISHED
}

enum ProductRequestStatus {
  NEW
  IN_REVIEW
  ACCEPTED
  REJECTED
  DONE
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         Role     @default(CUSTOMER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  orders   Order[]
  posts    BlogPost[]   @relation("PostAuthor")
  profile  Profile?
}

// Singleton-ish profile owned by an admin user
model Profile {
  id            String  @id @default(cuid())
  userId        String  @unique
  user          User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  displayName   String
  headline      String?
  about         String? @db.Text
  photoUrl      String?
  address       String?
  email         String?
  phone         String?
  websiteUrl    String?
  socials       Json?   // { github, linkedin, x, ... }
  qualifications Qualification[]
  experiences   Experience[]
  skills        Skill[]
  updatedAt     DateTime @updatedAt
}

model Qualification {
  id         String   @id @default(cuid())
  profileId  String
  profile    Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  title      String
  institution String
  startYear  Int?
  endYear    Int?
  description String?
  order      Int      @default(0)
}

model Experience {
  id         String   @id @default(cuid())
  profileId  String
  profile    Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  role       String
  company    String
  startYear  Int?
  endYear    Int?
  current    Boolean  @default(false)
  description String?
  order      Int      @default(0)
}

model Skill {
  id        String  @id @default(cuid())
  profileId String
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  name      String
  level     Int     @default(3) // 1-5
  category  String?
  order     Int     @default(0)
}

model Project {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  summary     String
  description String   @db.Text
  techStack   String[]
  link        String?
  repoUrl     String?
  imageUrl    String?
  featured    Boolean  @default(false)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Category {
  id        String     @id @default(cuid())
  name      String     @unique
  slug      String     @unique
  type      String     // "product" | "blog"
  products  Product[]
  posts     BlogPost[]
  createdAt DateTime   @default(now())
}

model Product {
  id           String     @id @default(cuid())
  name         String
  slug         String     @unique
  description  String     @db.Text
  priceCents   Int
  currency     String     @default("USD")
  fileUrl      String?    // private file for digital download
  imageUrl     String?
  published    Boolean    @default(true)
  categoryId   String?
  category     Category?  @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  orderItems   OrderItem[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Order {
  id            String      @id @default(cuid())
  userId        String?
  user          User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  email         String
  // WhatsApp number or other contact phone supplied by the buyer at checkout.
  // Nullable in DB to keep historical orders importable; required at the API/UI layer.
  customerPhone String?
  totalCents    Int
  currency      String      @default("USD")
  status        OrderStatus @default(PENDING)
  items         OrderItem[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model OrderItem {
  id         String  @id @default(cuid())
  orderId    String
  order      Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId  String
  product    Product @relation(fields: [productId], references: [id])
  priceCents Int
  quantity   Int     @default(1)
}

model BlogPost {
  id              String     @id @default(cuid())
  title           String
  slug            String     @unique
  excerpt         String?
  content         String     @db.Text
  coverImageUrl   String?
  status          PostStatus @default(DRAFT)
  publishedAt     DateTime?
  authorId        String
  author          User       @relation("PostAuthor", fields: [authorId], references: [id])
  categoryId      String?
  category        Category?  @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  tags            String[]
  metaTitle       String?
  metaDescription String?
  metaKeywords    String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@index([status, publishedAt])
}

model Message {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String?
  body      String   @db.Text
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

// Anyone (no login) can submit a request describing a product / template / service
// they would like the admin to build or list. Admins triage these from the panel.
model ProductRequest {
  id          String               @id @default(cuid())
  name        String
  email       String
  phone       String               // WhatsApp number or other contact
  title       String
  description String               @db.Text
  budget      String?              // Free-text budget (e.g. "$500", "Open to discuss")
  status      ProductRequestStatus @default(NEW)
  adminNote   String?              @db.Text
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@index([status, createdAt])
}

model AnalyticsEvent {
  id         String   @id @default(cuid())
  path       String
  referrer   String?
  visitorId  String?  // anonymous id from cookie
  ip         String?
  userAgent  String?
  country    String?
  createdAt  DateTime @default(now())

  @@index([path, createdAt])
  @@index([visitorId, createdAt])
}
